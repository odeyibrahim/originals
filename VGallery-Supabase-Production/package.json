{
  "name": "vgallery-supabase-production",
  "version": "3.0.0",
  "description": "V. Gallery - Production E-commerce Platform with Supabase",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "netlify:dev": "netlify dev",
    "db:migrate": "node scripts/migrate-database.js",
    "db:seed": "node scripts/seed-database.js",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "setup:all": "npm install && npm run db:migrate && npm run db:seed",
    "analyze": "vite build --mode analyze",
    "security:audit": "npm audit && node scripts/security-audit.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@supabase/ssr": "^0.1.0",
    "crypto-js": "^4.2.0",
    "joi": "^17.13.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "@sendgrid/mail": "^8.1.0",
    "cloudinary": "^2.0.0",
    "@upstash/redis": "^1.28.0",
    "@sentry/node": "^7.100.0",
    "@sentry/browser": "^7.100.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@netlify/functions": "^2.6.0",
    "netlify-cli": "^17.0.0",
    "vite": "^5.1.0",
    "terser": "^5.29.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "dotenv": "^16.4.0"
  }
}
